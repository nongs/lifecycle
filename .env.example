# ——— 데이터: local (demo) | db (cloud) ———
# NEXT_PUBLIC_DATA_VARIANT=demo
# NEXT_PUBLIC_APP_VARIANT=cloud   # DATA_VARIANT 와 동일 (하위 호환)

# ——— 셸: web | webapp (PWA) ———
# NEXT_PUBLIC_SHELL_VARIANT=web

# B-1 Supabase (cloud 빌드 — dev:cloud / build:cloud)
# Dashboard: schema.sql 실행
# Auth → URL Configuration → Redirect URLs 에 {origin}{basePath}/settings/login 추가
#   예: http://localhost:3000/settings/login
#       https://your.domain/lifecycle-app/settings/login
#
# ☐ 운영·메일 한도: Custom SMTP (나중) — markdown/LifeCycle_Ops_Checklist.md
#   기본 SMTP는 시간당 2~4통 → "email rate limit exceeded"
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
