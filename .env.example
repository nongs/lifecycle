# LifeCycle 환경 변수
#
# ┌─────────────┬──────────────────────────────────────────────────┐
# │ 용도        │ 파일                                              │
# ├─────────────┼──────────────────────────────────────────────────┤
# │ 로컬 dev    │ .env.local (gitignore) — cloud dev 시 Supabase   │
# │ demo 빌드   │ .env.build.demo (커밋됨)                          │
# │ cloud 빌드  │ .env.build.cloud + .env.build.cloud.secrets.local │
# │ PWA 빌드    │ .env.build.webapp.cloud + secrets.local (공유)   │
# └─────────────┴──────────────────────────────────────────────────┘
#
# cloud 빌드 secrets 최초 설정:
#   cp .env.build.cloud.secrets.example .env.build.cloud.secrets.local
#   (.env.local 과 동일한 Supabase URL·anon key 입력)

# ——— 로컬 개발 (dev / dev:cloud) ———
# NEXT_PUBLIC_APP_VARIANT=cloud
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ——— 참고: variant / shell / basePath 는 빌드 env 파일에 정의 ———
# .env.build.demo | .env.build.cloud | .env.build.webapp.cloud

# Supabase Dashboard
# - schema.sql 실행
# - Redirect URLs: {origin}{basePath}/settings/login
# - Custom SMTP: 나중 — markdown/LifeCycle_Ops_Checklist.md
