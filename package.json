{
  "name": "lifecycle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_PUBLIC_APP_VARIANT=demo next dev",
    "dev:cloud": "NEXT_PUBLIC_APP_VARIANT=cloud next dev",
    "dev:webapp:cloud": "NEXT_PUBLIC_APP_VARIANT=cloud NEXT_PUBLIC_SHELL_VARIANT=webapp next dev",
    "build": "npm run build:demo",
    "build:demo": "dotenv -e .env.build.demo -- next build",
    "build:cloud": "dotenv -c -e .env.build.cloud -e .env.build.cloud.secrets.local -- next build",
    "build:webapp:cloud": "dotenv -c -e .env.build.webapp.cloud -e .env.build.cloud.secrets.local -- next build",
    "lint": "next lint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
